{
	"schemaVersion": 1,
	"id": "revivebydeath",
	"version": "${version}",
	"name": "ReviveByDeath",
	"description": "Replaces fatal moments with a cinematic rewind, restoring players to safe checkpoints.",
	"authors": [
		"KhangHy"
	],
	"license": "MIT",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.khanghy.revivebydeath.ReviveByDeath"
		],
		"client": [
			"com.khanghy.revivebydeath.client.ReviveByDeathClient"
		]
	},
	"mixins": [
		"revivebydeath.mixins.json",
		{
			"config": "revivebydeath.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~1.21.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}
